localplayer.CharacterAdded:Connect(function()
    if fly_bg or fly_bv then fly_stop() end
end)

local spectating = false
local spectated_player = nil

PlayersTab:PlayerList({
    Name = "Playerlist", 
    Flag = "Playerlist", 
    Callback = function(player)
        spectated_player = player
        if player and player.Character then
            local hum = player.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                spectating = true
                workspace.CurrentCamera.CameraSubject = hum
                workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
            end
        elseif spectating then
            spectating = false
            local lc = localplayer.Character
            local lh = lc and lc:FindFirstChildOfClass("Humanoid")
            workspace.CurrentCamera.CameraSubject = lh
            workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
        end
    end
})

user_input_service.InputBegan:Connect(function(input, g_processed)
    if g_processed then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        if spectating then
            spectating = false
            local lc = localplayer.Character
            local lh = lc and lc:FindFirstChildOfClass("Humanoid")
            workspace.CurrentCamera.CameraSubject = lh
            workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
        end
    end
end)

local PlayerTeleportSection = PlayersTab:Section({Name = "Teleport", Side = 1})
PlayerTeleportSection:Dropdown({
    Name = "Action",
    Items = {"Teleport"},
    Default = "Teleport",
    Flag = "PlayerTeleport",
    Callback = function()
        if not spectated_player or not spectated_player.Character then return end
        local hrp = spectated_player.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        local lc = localplayer.Character
        local lhrp = lc and lc:FindFirstChild("HumanoidRootPart")
        if lhrp then
            lhrp.CFrame = hrp.CFrame * CFrame.new(0, 0, 5)
        end
    end
})

