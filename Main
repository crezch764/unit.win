    Flag = "EspFadeDist",
    Callback = function(v) ESP.FadeOut.OnDistance = v end
})

-- Color controls (Side 2)
EspSection2:Toggle({
    Name = "Box Outline Color",
    Default = true,
    Flag = "EspBoxColToggle",
    Callback = function(v)
        if not v then ESP.Drawing.Boxes.Full.RGB = Color3.fromRGB(255, 255, 255) end
    end
}):Colorpicker({
    Name = "Box Outline Color",
    Flag = "EspBoxColor",
    Default = ESP.Drawing.Boxes.Full.RGB,
    Callback = function(c) ESP.Drawing.Boxes.Full.RGB = c end
})

