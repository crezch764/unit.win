    Name = "Corner Color",
    Default = true,
    Flag = "EspCornerColToggle",
    Callback = function(v)
        if not v then ESP.Drawing.Boxes.Corner.RGB = Color3.fromRGB(255, 255, 255) end
    end
}):Colorpicker({
    Name = "Corner Color",
    Flag = "EspCornerColor",
    Default = ESP.Drawing.Boxes.Corner.RGB,
    Callback = function(c) ESP.Drawing.Boxes.Corner.RGB = c end
})

