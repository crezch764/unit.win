local maxspeed = 50
local fly_ctrl = {f = 0, b = 0, l = 0, r = 0}
local fly_speed = 0
local fly_bg = nil
local fly_bv = nil
local fly_loop = nil

local function fly_stop()
    if fly_loop then fly_loop:Disconnect(); fly_loop = nil end
    if fly_bg then fly_bg:Destroy(); fly_bg = nil end
    if fly_bv then fly_bv:Destroy(); fly_bv = nil end
    local char = localplayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.PlatformStand = false end
        local anim = char:FindFirstChild("Animate")
        if anim then anim.Disabled = false end
    end
    fly_ctrl = {f = 0, b = 0, l = 0, r = 0}
    fly_speed = 0
end

local function fly_start()
    fly_stop()
    local char = localplayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local part = char and (hum and hum.RigType == Enum.HumanoidRigType.R6 and char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso"))
    if not part or not hum then return end

    hum.PlatformStand = true
    local anim = char:FindFirstChild("Animate")
    if anim then anim.Disabled = true end

    for _, track in ipairs(hum:GetPlayingAnimationTracks()) do
        track:AdjustSpeed(0)
    end

    fly_bg = Instance.new("BodyGyro", part)
    fly_bg.P = 9e4
    fly_bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    fly_bg.CFrame = part.CFrame

    fly_bv = Instance.new("BodyVelocity", part)
    fly_bv.Velocity = Vector3.new(0, 0.1, 0)
    fly_bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)

    local lastctrl = {f = 0, b = 0, l = 0, r = 0}
    fly_loop = run_service.RenderStepped:Connect(function()
        if not fly_bv or not fly_bv.Parent then fly_stop(); return end

        fly_ctrl.f = user_input_service:IsKeyDown(Enum.KeyCode.W) and 1 or 0
        fly_ctrl.b = user_input_service:IsKeyDown(Enum.KeyCode.S) and 1 or 0
        fly_ctrl.l = user_input_service:IsKeyDown(Enum.KeyCode.A) and 1 or 0
        fly_ctrl.r = user_input_service:IsKeyDown(Enum.KeyCode.D) and 1 or 0

        if user_input_service:IsKeyDown(Enum.KeyCode.Space) then
            part.CFrame = part.CFrame * CFrame.new(0, maxspeed * 0.03, 0)
        end
        if user_input_service:IsKeyDown(Enum.KeyCode.LeftShift) then
            part.CFrame = part.CFrame * CFrame.new(0, -maxspeed * 0.03, 0)
        end

        if fly_ctrl.l + fly_ctrl.r ~= 0 or fly_ctrl.f + fly_ctrl.b ~= 0 then
            fly_speed = fly_speed + 0.5 + (fly_speed / maxspeed)
            if fly_speed > maxspeed then fly_speed = maxspeed end
        elseif fly_speed ~= 0 then
            fly_speed = fly_speed - 1
            if fly_speed < 0 then fly_speed = 0 end
        end

        local cam = workspace.CurrentCamera
        if fly_ctrl.l + fly_ctrl.r ~= 0 or fly_ctrl.f + fly_ctrl.b ~= 0 then
            fly_bv.Velocity = ((cam.CFrame.LookVector * (fly_ctrl.f - fly_ctrl.b)) + ((cam.CFrame * CFrame.new(fly_ctrl.r - fly_ctrl.l, (fly_ctrl.f - fly_ctrl.b) * 0.2, 0).p) - cam.CFrame.p)) * fly_speed
            lastctrl = {f = fly_ctrl.f, b = fly_ctrl.b, l = fly_ctrl.l, r = fly_ctrl.r}
        elseif fly_speed ~= 0 then
            fly_bv.Velocity = ((cam.CFrame.LookVector * (lastctrl.f - lastctrl.b)) + ((cam.CFrame * CFrame.new(lastctrl.r - lastctrl.l, (lastctrl.f - lastctrl.b) * 0.2, 0).p) - cam.CFrame.p)) * fly_speed
        else
            fly_bv.Velocity = Vector3.new(0, 0, 0)
        end

        fly_bg.CFrame = cam.CFrame * CFrame.Angles(-math.rad((fly_ctrl.f - fly_ctrl.b) * 50 * fly_speed / maxspeed), 0, 0)
    end)
end

local FlyToggle = MiscSection:Toggle({
    Name = "Fly",
    Default = false,
    Flag = "FlyToggle",
    Callback = function(v)
        if v then fly_start() else fly_stop() end
    end
})
