    Callback = function(v) ESP.Drawing.Distances.Position = v end
})

EspSection1:Toggle({
    Name = "Flags",
    Default = true,
    Flag = "EspFlags",
    Callback = function(v) ESP.Drawing.Flags.Enabled = v end
})

EspSection1:Toggle({
    Name = "Tracers",
    Default = false,
    Flag = "EspTracers",
    Callback = function(v) ESP.Drawing.Tracers.Enabled = v end
})

EspSection1:Dropdown({
    Name = "Tracer Mode",
    Items = {"Bottom", "Mouse", "Top"},
    Default = "Bottom",
    Flag = "EspTracerMode",
    Callback = function(v) ESP.Drawing.Tracers.Mode = v end
})

EspSection1:Toggle({
    Name = "Chams",
    Default = true,
    Flag = "EspChams",
    Callback = function(v) ESP.Drawing.Chams.Enabled = v end
})

