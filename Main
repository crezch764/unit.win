local LoadingTick = os.clock()

local Library = (function()
    local success, raw = pcall(game.HttpGet, game, "https://raw.githubusercontent.com/sametexe001/sametlibs/refs/heads/main/Zoophack/Library.lua")
    if not success then warn("HTTP request failed:", raw); return {} end
    local fn, err = loadstring(raw)
    if not fn then warn("Library syntax error:", err); return {} end
    local ok, result = pcall(fn)
    if not ok then warn("Library runtime error:", result); return {} end
    return result
end)()
